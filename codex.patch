+                            markPlacedBlockWetIfDry(world, targetPos, wetUntil, gameTime);
                         }
                     }
                 }
             }
         }
     }
 
     private static void applyRainWetState(ServerWorld world, long gameTime) {
         if (!world.isRaining()) {
             return;
         }
 
         int playerCount = world.players().size();
         if (playerCount == 0) {
             return;
         }
 
