         ServerWorld world = (ServerWorld) event.getWorld();
         BlockPos waterPos = event.getPos();
         if (!world.getFluidState(waterPos).is(FluidTags.WATER) && !event.getNewState().getFluidState().is(FluidTags.WATER)) {
