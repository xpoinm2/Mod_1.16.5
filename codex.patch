         CompoundNBT copy = tag.copy();
         INBT wet = copy.get(WET_TAG);
         if (wet != null) {
             copy.remove(WET_TAG);
         }
         INBT wetUntil = copy.get(WET_UNTIL_TAG);
         if (wetUntil != null) {
