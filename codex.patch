         }
 
         if (first.getDamageValue() != second.getDamageValue()) {
             return false;
         }
 
         if (first.getCount() >= first.getMaxStackSize()) {
             return false;
         }
 
         return sameTagExceptWetData(first.getTag(), second.getTag());
